# =============================================================================
# Copie este arquivo para .env na RAIZ do monorepo:
#   cp .env.example .env
#
# O apps/web/.env.local pode ser gerado com:
#   cp .env.example apps/web/.env.local
# (use apenas NEXT_PUBLIC_API_URL no .env.local do Next.js)
# =============================================================================

# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plataforma_candidato?schema=public"

# API (Fastify)
API_PORT=3333
API_HOST=0.0.0.0
JWT_SECRET="altere-esta-chave-em-producao-com-uma-string-segura-de-pelo-menos-32-caracteres"
FRONTEND_URL="http://localhost:3000"

# Frontend (Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3333"
