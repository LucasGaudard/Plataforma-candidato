generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDINATOR
  LEADER
  USER
}

enum PostCategory {
  VIDEO
  LIVE
  COMUNICADO
  EVENTO
  GERAL
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  EVENT
  POST
  LIVE
}

enum SupporterStatus {
  PENDING
  VERIFIED
  INVALID
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  cpf           String         @unique
  phone         String
  address       String
  city          String
  state         String
  role          Role           @default(USER)
  status        SupporterStatus @default(PENDING)
  leaderSlug    String?        @unique
  leaderId      String?
  leader        User?          @relation("LeaderSupporters", fields: [leaderId], references: [id], onDelete: SetNull)
  supporters    User[]         @relation("LeaderSupporters")
  coordinatorId String?
  coordinator   User?          @relation("CoordinatorLeaders", fields: [coordinatorId], references: [id], onDelete: SetNull)
  leaders       User[]         @relation("CoordinatorLeaders")
  posts         Post[]
  events        Event[]
  lives         Live[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([leaderId])
  @@index([coordinatorId])
  @@index([role])
  @@index([leaderSlug])
  @@index([createdAt])
}

model Post {
  id          String       @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  videoUrl    String?
  category    PostCategory @default(GERAL)
  publishedAt DateTime     @default(now())
  published   Boolean      @default(true)
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([published, publishedAt])
  @@index([category])
  @@index([authorId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String
  date        DateTime
  time        String
  published   Boolean  @default(true)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, date])
  @@index([authorId])
}

model Live {
  id           String    @id @default(cuid())
  title        String
  description  String
  thumbnailUrl String?
  youtubeUrl   String
  published    Boolean   @default(true)
  scheduledAt  DateTime?
  authorId     String
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([published, scheduledAt])
  @@index([authorId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean          @default(false)
  type      NotificationType @default(INFO)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}
