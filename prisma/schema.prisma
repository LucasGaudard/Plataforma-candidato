generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  LEADER
  USER
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  firstName  String
  lastName   String
  cpf        String   @unique
  phone      String
  address    String
  city       String
  state      String
  role       Role     @default(USER)
  leaderSlug String?  @unique
  leaderId   String?
  leader     User?    @relation("LeaderSupporters", fields: [leaderId], references: [id], onDelete: SetNull)
  supporters User[]   @relation("LeaderSupporters")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([leaderId])
  @@index([role])
  @@index([leaderSlug])
}
